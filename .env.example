# Ryujin Bot Environment Configuration
# Copy this file to .env and fill in your values

# Discord Bot Token
RYUJIN_TOKEN=your_bot_token_here

# Groq AI API Key (for Ryujin AI chat)
GROQ_API_KEY=your_groq_api_key_here

# MySQL Database
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=your_db_password
DB_NAME=ryujin

# Discord Channel IDs
WELCOME_LEAVE_CHANNEL_ID=1061417513579196516

# External APIs
WHATFONTIS_API_KEY=your_whatfontis_api_key_here
REMOVEBG_API_URL=http://191.96.94.248:5080/remove-bg
